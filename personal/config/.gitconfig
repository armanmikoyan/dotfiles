[init]
	defaultbranch = main

[rerere]
	enabled = true

[pull]
	rebase = true

[color]
	ui = auto

[color "branch"]
	current = yellow bold
	local = green
	remote = red

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red
	new = green

[color "status"]
	added = green
	changed = yellow
	untracked = red

[include]
	path = ~/.gitconfig.local
